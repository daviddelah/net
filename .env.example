# Database (Turso remote or local file)
# For local development, leave empty to use ./data/net.db
# For production/CI, set your Turso URL and token
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Farcaster (Neynar API)
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_CLIENT_ID=your_neynar_client_id
FARCASTER_SIGNER_UUIDS=your_signer_uuid_1,your_signer_uuid_2

# Twitter/X (bird CLI cookies)
AUTH_TOKEN=your_twitter_auth_token
CT0=your_twitter_ct0_cookie

# Server
PORT=3000

# Timezone (for queue slots)
# TZ=America/New_York
