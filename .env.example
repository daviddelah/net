# Neynar (Farcaster) API
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_CLIENT_ID=your_neynar_client_id
FARCASTER_SIGNER_UUIDS=your_signer_uuid_1,your_signer_uuid_2

# Farcaster monitoring
TRACKED_ACCOUNTS=dwr,vitalik.eth,jesse,bitfloorsghost.eth,deployer
ACCOUNT_BOOST_MULTIPLIER=1.5
TRACKED_CHANNELS=base,degen,farcaster,memes,replyguys
KEYWORDS=memecoin,airdrop,launch,token,ai,claude,moot

# Timing
POLL_INTERVAL_MS=300000
LAUNCH_COOLDOWN_MS=300000

# Thresholds
VIRALITY_THRESHOLD=60
MAX_LAUNCHES_PER_DAY=10

# Dashboard
DASHBOARD_PORT=3000

# Database (optional - defaults to ./data/launches.db)
# DB_PATH=/data/launches.db

# Twitter/X cookies for bird CLI (optional)
AUTH_TOKEN=your_twitter_auth_token
CT0=your_twitter_ct0_cookie
